<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/flipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:paddingStart="32dp" android:paddingEnd="32dp">
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.8" />
        <ImageView android:layout_width="112dp" android:layout_height="112dp" android:src="@drawable/logo_header" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="@string/app_name" android:textColor="@color/white" android:textSize="40sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/welcome_tagline" android:textColor="@color/gold" android:textSize="15sp" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="40dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/welcome_f1" android:textColor="@color/white" android:textSize="15sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/welcome_f2" android:textColor="@color/white" android:textSize="15sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/welcome_f3" android:textColor="@color/white" android:textSize="15sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/welcome_f4" android:textColor="@color/white" android:textSize="15sp" />
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
        <TextView android:id="@+id/btnStart" android:layout_width="match_parent" android:layout_height="58dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="@string/get_started" android:textColor="#0A1128" android:textSize="17sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:layout_marginBottom="26dp" android:alpha="0.55" android:text="@string/footer" android:textColor="@color/white" android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="36dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱" android:textSize="60sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/overlay_title" android:textColor="@color/gold" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center" android:text="@string/overlay_desc" android:textColor="@color/white" android:textSize="15sp" android:lineSpacingExtra="4dp" />
        <TextView android:id="@+id/btnGrantOverlay" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="32dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="@string/grant_permission" android:textColor="#0A1128" android:textSize="16sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="36dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎵" android:textSize="60sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/audio_title" android:textColor="@color/gold" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center" android:text="@string/audio_desc" android:textColor="@color/white" android:textSize="14sp" android:lineSpacingExtra="4dp" />
        <TextView android:id="@+id/btnGrantAudio" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="28dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="@string/grant_permission" android:textColor="#0A1128" android:textSize="16sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/btnSkipAudio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:padding="10dp" android:text="@string/skip" android:textColor="@color/text_muted" android:textSize="14sp" android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="36dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔔" android:textSize="60sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/notif_title" android:textColor="@color/gold" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center" android:text="@string/notif_desc" android:textColor="@color/white" android:textSize="15sp" android:lineSpacingExtra="4dp" />
        <TextView android:id="@+id/btnGrantNotif" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="28dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="@string/grant_permission" android:textColor="#0A1128" android:textSize="16sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/btnSkipNotif" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:padding="10dp" android:text="@string/skip" android:textColor="@color/text_muted" android:textSize="14sp" android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <ViewFlipper android:id="@+id/tabs" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/app_name" android:textColor="@color/gold" android:textSize="28sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:alpha="0.8" android:text="@string/status_stopped" android:textColor="@color/white" android:textSize="13sp" />
                    <TextView android:id="@+id/btnToggle" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="18dp" android:background="@drawable/btn_primary" android:gravity="center" android:text="@string/start_glow" android:textColor="#0A1128" android:textSize="17sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
                    <TextView android:id="@+id/btnTest" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="10dp" android:background="@drawable/btn_ghost" android:gravity="center" android:text="@string/test_glow" android:textColor="@color/gold" android:textSize="14sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
                    <FrameLayout android:layout_width="match_parent" android:layout_height="150dp" android:layout_marginTop="20dp" android:background="@drawable/bg_card">
                        <com.innovation313.glowedge.PreviewView android:id="@+id/preview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|start" android:layout_margin="12dp" android:alpha="0.5" android:text="@string/live_preview" android:textColor="@color/text_muted" android:textSize="11sp" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:layout_marginBottom="14dp" android:text="@string/styles_header" android:textColor="@color/gold" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.12" />
                    <LinearLayout android:id="@+id/stylesBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>
            </ScrollView>

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/settings" android:textColor="@color/gold" android:textSize="28sp" android:textStyle="bold" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="24dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/music_only" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />
                        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchMusicOnly" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:alpha="0.7" android:text="@string/music_only_desc" android:textColor="@color/white" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/music_sensitivity" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:alpha="0.6" android:text="@string/music_sensitivity_desc" android:textColor="@color/white" android:textSize="12sp" />
                    <SeekBar android:id="@+id/seekSensitivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="#22FFFFFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:layout_marginBottom="12dp" android:text="@string/themes_header" android:textColor="@color/gold" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.12" />
                    <LinearLayout android:id="@+id/themesBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/thickness" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/seekThickness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/speed" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/seekSpeed" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/intensity" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                    <SeekBar android:id="@+id/seekIntensity" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#22FFFFFF" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="24dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/battery_saver" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />
                        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchSaver" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:alpha="0.7" android:text="@string/battery_saver_desc" android:textColor="@color/white" android:textSize="13sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="24dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/autostart" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />
                        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchAutostart" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:alpha="0.7" android:text="@string/autostart_desc" android:textColor="@color/white" android:textSize="13sp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#22FFFFFF" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="24dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/notif_glow" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" />
                        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchNotifGlow" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:alpha="0.7" android:text="@string/notif_glow_desc" android:textColor="@color/white" android:textSize="13sp" />
                    <TextView android:id="@+id/btnNotifAccess" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:layout_marginBottom="20dp" android:background="@drawable/btn_ghost" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="12dp" android:paddingBottom="12dp" android:text="@string/notif_glow_grant" android:textColor="@color/gold" android:textSize="14sp" android:textStyle="bold" android:clickable="true" android:focusable="true" />
                </LinearLayout>
            </ScrollView>

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/about_title" android:textColor="@color/gold" android:textSize="28sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/about_intro" android:textColor="@color/white" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="@string/how_header" android:textColor="@color/gold" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:lineSpacingExtra="7dp" android:text="@string/how_menus" android:textColor="@color/white" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="@string/detect_header" android:textColor="@color/gold" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:lineSpacingExtra="7dp" android:text="@string/detect_desc" android:textColor="@color/white" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="@string/features_header" android:textColor="@color/gold" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:lineSpacingExtra="8dp" android:text="@string/features_text" android:textColor="@color/white" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="@string/privacy_header" android:textColor="@color/gold" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:lineSpacingExtra="6dp" android:text="@string/privacy_text" android:textColor="@color/white" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="@string/copyright_header" android:textColor="@color/gold" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:layout_marginBottom="20dp" android:lineSpacingExtra="6dp" android:text="@string/copyright_text" android:textColor="@color/white" android:textSize="13sp" />
                </LinearLayout>
            </ScrollView>
        </ViewFlipper>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/bottomNav" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/surface" app:menu="@menu/bottom_nav" app:labelVisibilityMode="labeled" />
    </LinearLayout>
</ViewFlipper>
